# ─── App ────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_KEY_MIN_32_CHARS

# ─── PostgreSQL ──────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=copytrade
POSTGRES_USER=copytrade
POSTGRES_PASSWORD=copytrade
DATABASE_URL=postgresql+asyncpg://copytrade:copytrade@localhost:5432/copytrade

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Telegram ────────────────────────────────────────
# Required: get from @BotFather
TELEGRAM_BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN
TELEGRAM_WEBHOOK_SECRET=change-me-random-string
# Comma-separated Telegram IDs allowed to use admin analytics endpoints.
ADMIN_TELEGRAM_IDS=

# ─── Wallet / Agents ─────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of agent private keys
# Generate with: openssl rand -hex 32
# WARNING: rotating this key invalidates ALL stored agent wallets
AGENT_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS

# ─── Hyperliquid ─────────────────────────────────────
HL_NETWORK=mainnet  # mainnet | testnet
HL_TESTNET_API_URL=https://api.hyperliquid-testnet.xyz
HL_MAINNET_API_URL=https://api.hyperliquid.xyz
# Rate limiter (HL throttles ~1200 weight/min per IP). Lower HL_RATE_PER_SEC if 429s persist.
HL_RATE_PER_SEC=18.0
HL_RATE_CAPACITY=80.0
HL_RATE_LOW_PRIO_RESERVE=40.0
# Cap traders processed by the hourly quality-metrics job (each = 1 heavy userFills call)
HL_QUALITY_METRICS_MAX_TRADERS=1000

# ─── New HL Wallet Discovery ────────────────────────
# Disabled until a global funding-event provider/indexer is configured.
NEW_WALLET_DISCOVERY_ENABLED=false
NEW_WALLET_AUTO_ATTACH_ENABLED=false
NEW_WALLET_FUNDING_EVENTS_URL=
NEW_WALLET_FUNDING_EVENTS_API_KEY=
NEW_WALLET_CHAIN_BALANCE_THRESHOLD_USD=15000
NEW_WALLET_MAX_CHAIN_DEPTH=3
NEW_WALLET_SUBSCRIPTION_TTL_DAYS=5
NEW_WALLET_SCAN_INTERVAL_SECONDS=30
NEW_WALLET_DISCOVERY_LOOKBACK_HOURS=24
NEW_WALLET_MIN_INCOMING_AMOUNT_USD=100
NEW_WALLET_MAX_ACTIVE_PER_USER=20
NEW_WALLET_DEFAULT_MAX_PER_WALLET_USD=100
NEW_WALLET_MAX_CANDIDATES_PER_RUN=100
NEW_WALLET_MAX_ATTACH_PER_RUN=100

# ─── Builder Code ────────────────────────────────────
# Our wallet address for receiving protocol fees (0.05% per trade)
BUILDER_ADDRESS=0x0000000000000000000000000000000000000000
BUILDER_FEE_RATE=50        # tenth-bps: 50 = 0.05%
BUILDER_MAX_FEE_RATE=0.075%

# ─── Model Portfolio Billing ────────────────────────
BILLING_PROVIDER=stripe
# Optional until paid live activation is enabled publicly.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTFOLIO_PRICE_ID=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/portfolios
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/portfolios
# Comma-separated Telegram IDs that bypass billing during private beta.
MODEL_PORTFOLIO_BETA_OVERRIDE_TELEGRAM_IDS=

# ─── Model Portfolio Explanations ───────────────────
# Default template mode makes no external LLM calls.
MODEL_PORTFOLIO_EXPLANATIONS_PROVIDER=template
MODEL_PORTFOLIO_LLM_API_URL=
MODEL_PORTFOLIO_LLM_API_KEY=
MODEL_PORTFOLIO_LLM_MODEL=

# ─── Redis auth (production only) ────────────────────
# Dev: leave empty (no password). Production: set strong password, e.g. openssl rand -hex 32
REDIS_PASSWORD=

# ─── Frontend build ──────────────────────────────────
# Get free project ID at https://cloud.reown.com
VITE_WALLETCONNECT_PROJECT_ID=
