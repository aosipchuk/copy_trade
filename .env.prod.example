# ─── App ─────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX

# ─── Deployment target (metadata, no secrets) ────────
# This makes the production destination explicit for humans and agents.
DEPLOY_TARGET=copy_trade_production
DEPLOY_HOST=REPLACE_WITH_SERVER_IP_OR_DNS
DEPLOY_USER=REPLACE_WITH_SSH_USER
DEPLOY_PATH=/opt/copy_trade
DEPLOY_BRANCH=main
DEPLOY_EDGE=cloudflare-tunnel
DOMAIN=your.domain.com
PUBLIC_URL=https://your.domain.com
HEALTHCHECK_URL=https://your.domain.com/api/health
TELEGRAM_MINI_APP_URL=https://your.domain.com

# ─── PostgreSQL ──────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=copytrade
POSTGRES_USER=copytrade
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://copytrade:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/copytrade

# ─── Redis ───────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
REDIS_URL=redis://redis:6379/0

# ─── Telegram ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_STRING
# Comma-separated Telegram IDs allowed to use admin analytics endpoints.
ADMIN_TELEGRAM_IDS=

# ─── Wallet / Agents ─────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: rotating this key invalidates ALL stored agent keys
AGENT_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX

# ─── Hyperliquid ─────────────────────────────────────
HL_NETWORK=mainnet
# Rate limiter (HL throttles ~1200 weight/min per IP). Lower HL_RATE_PER_SEC if 429s persist.
HL_RATE_PER_SEC=18.0
HL_RATE_CAPACITY=80.0
HL_RATE_LOW_PRIO_RESERVE=40.0
# Cap traders processed by the 4h quality-metrics job (each = 1 heavy userFills call)
HL_QUALITY_METRICS_MAX_TRADERS=200

# ─── Builder Code ─────────────────────────────────────
# WARNING: must deposit 100 USDC on this address on Hyperliquid before mainnet launch
BUILDER_ADDRESS=REPLACE_WITH_YOUR_BUILDER_WALLET_ADDRESS
BUILDER_FEE_RATE=50        # tenth-bps: 50 = 0.05%
BUILDER_MAX_FEE_RATE=0.075%

# ─── Model Portfolio Billing ─────────────────────────
BILLING_PROVIDER=stripe
# Required before public paid live activation.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTFOLIO_PRICE_ID=
STRIPE_CHECKOUT_SUCCESS_URL=https://your.domain.com/portfolios
STRIPE_CHECKOUT_CANCEL_URL=https://your.domain.com/portfolios
# Comma-separated Telegram IDs that bypass billing during private beta.
MODEL_PORTFOLIO_BETA_OVERRIDE_TELEGRAM_IDS=

# ─── Model Portfolio Explanations ───────────────────
# Keep template unless an audited OpenAI-compatible provider is configured.
MODEL_PORTFOLIO_EXPLANATIONS_PROVIDER=template
MODEL_PORTFOLIO_LLM_API_URL=
MODEL_PORTFOLIO_LLM_API_KEY=
MODEL_PORTFOLIO_LLM_MODEL=

# ─── Frontend (Vite build-time vars) ─────────────────
VITE_API_URL=https://your.domain.com/api
VITE_WS_URL=wss://your.domain.com/api
VITE_WALLETCONNECT_PROJECT_ID=REPLACE_WITH_REOWN_PROJECT_ID
VITE_APP_URL=https://your.domain.com
